# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string (e.g. Neon, Supabase, local Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Long random string used to sign admin JWTs. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"

# Public site URL (used for canonical links, sitemap, etc.)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Public contact details shown on the site
NEXT_PUBLIC_WHATSAPP="91XXXXXXXXXX"
NEXT_PUBLIC_PHONE="+91XXXXXXXXXX"
NEXT_PUBLIC_EMAIL="info@hariomenterprises.com"
