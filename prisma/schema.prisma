generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  @@map("admins")
}

model Brand {
  id          Int       @id @default(autoincrement())
  brandName   String    @map("brand_name")
  brandLogo   String?   @map("brand_logo")
  description String?
  category    String?
  createdAt   DateTime  @default(now()) @map("created_at")
  products    Product[]
  @@map("brands")
}

model Product {
  id           Int         @id @default(autoincrement())
  productName  String      @map("product_name")
  brandId      Int         @map("brand_id")
  category     String
  image        String?
  images       String?     
  description  String?     
  features     String?     
  specs        String?     
  createdAt    DateTime    @default(now()) @map("created_at")
  brand        Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  inquiries    Inquiry[]
  @@map("products")
}

model ColorShade {
  id        Int      @id @default(autoincrement())
  name      String
  hex       String
  family    String
  brand     String?
  createdAt DateTime @default(now()) @map("created_at")
  @@index([brand])
  @@map("color_shades")
}

model ContractorApplication {
  id           Int      @id @default(autoincrement())
  name         String
  businessName String?  @map("business_name")
  phone        String
  email        String?
  city         String?
  workType     String?  @map("work_type")
  message      String?
  status       String   @default("new")
  createdAt    DateTime @default(now()) @map("created_at")
  @@map("contractor_applications")
}

model ContractorRequest {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  address   String
  status    String   @default("new")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("contractor_requests")
}

model Offer {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  discount    String?
  code        String?
  image       String?
  active      Boolean   @default(true)
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  @@map("offers")
}

model WarrantyRegistration {
  id                Int       @id @default(autoincrement())
  warrantyId        String    @unique @map("warranty_id")
  customerName      String    @map("customer_name")
  mobile            String
  email             String
  address           String
  city              String
  district          String
  pincode           String
  brandName         String    @map("brand_name")
  productName       String    @map("product_name")
  shadeName         String?   @map("shade_name")
  batchNumber       String?   @map("batch_number")
  purchaseDate      DateTime  @map("purchase_date")
  quantityPurchased String?   @map("quantity_purchased")
  invoiceNumber     String?   @map("invoice_number")
  propertyType      String?   @map("property_type")
  paintedArea       String?   @map("painted_area")
  contractorName    String?   @map("contractor_name")
  applicationDate   DateTime? @map("application_date")
  invoiceFile       String    @map("invoice_file")
  productPhoto      String?   @map("product_photo")
  wallPhoto         String?   @map("wall_photo")
  status            String    @default("Pending")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  @@map("warranty_registrations")
}

// ───────────────────────── Scratch & Win ─────────────────────────

model ScratchUser {
  id        Int           @id @default(autoincrement())
  fullName  String        @map("full_name")
  mobile    String        @unique
  email     String?
  createdAt DateTime      @default(now()) @map("created_at")
  cards     ScratchCard[]
  @@index([mobile])
  @@map("scratch_users")
}

model ScratchCampaign {
  id                 Int           @id @default(autoincrement())
  title              String
  startDate          DateTime?     @map("start_date")
  endDate            DateTime?     @map("end_date")
  couponValidityDays Int           @default(30) @map("coupon_validity_days")
  isActive           Boolean       @default(true) @map("is_active")
  createdAt          DateTime      @default(now()) @map("created_at")
  cards              ScratchCard[]
  @@map("scratch_campaigns")
}

model ScratchReward {
  id           Int           @id @default(autoincrement())
  title        String
  description  String?
  couponPrefix String        @map("coupon_prefix")
  probability  Float         @default(1)
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  cards        ScratchCard[]
  @@map("scratch_rewards")
}

model ScratchCard {
  id          Int                @id @default(autoincrement())
  userId      Int                @map("user_id")
  campaignId  Int                @map("campaign_id")
  rewardId    Int                @map("reward_id")
  couponCode  String             @unique @map("coupon_code")
  status      String             @default("ISSUED") // ISSUED · SCRATCHED · REDEEMED · EXPIRED
  scratchedAt DateTime?          @map("scratched_at")
  redeemedAt  DateTime?          @map("redeemed_at")
  expiresAt   DateTime?          @map("expires_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  user        ScratchUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign    ScratchCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reward      ScratchReward      @relation(fields: [rewardId], references: [id], onDelete: Restrict)
  redemption  CouponRedemption?
  @@index([couponCode])
  @@index([status])
  @@map("scratch_cards")
}

model CouponRedemption {
  id             Int         @id @default(autoincrement())
  cardId         Int         @unique @map("card_id")
  invoiceNumber  String?     @map("invoice_number")
  purchaseAmount Float?      @map("purchase_amount")
  redeemedBy     String?     @map("redeemed_by")
  redeemedAt     DateTime    @default(now()) @map("redeemed_at")
  card           ScratchCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  @@map("coupon_redemptions")
}

model Inquiry {
  id           Int      @id @default(autoincrement())
  customerName String   @map("customer_name")
  phone        String
  email        String?
  message      String?  
  productId    Int?     @map("product_id")
  status       String   @default("new")
  createdAt    DateTime @default(now()) @map("created_at")
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  @@map("inquiries")
}
